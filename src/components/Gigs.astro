---
import { client } from '../lib/sanity';
import type { Gig } from '../lib/types';

const gigs: Gig[] = await client
  .fetch(`*[_type == "gig" && date >= now()] | order(date asc)`)
  .catch(() => []);

const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return {
    day: date.toLocaleDateString('en-SE', { day: '2-digit' }),
    month: date.toLocaleDateString('en-SE', { month: 'short' }).toUpperCase(),
    weekday: date.toLocaleDateString('en-SE', { weekday: 'long' }),
  };
};
---

<section id="live" class="py-24 md:py-36 bg-n-white">
  <div class="max-w-4xl mx-auto px-6">

    <div class="text-center mb-16">
      <p class="text-n-clay text-xs tracking-[0.4em] uppercase font-light mb-4">Upcoming</p>
      <h2 class="font-serif text-n-ink text-3xl md:text-4xl font-normal italic">Live</h2>
      <div class="w-8 h-px bg-n-stone mx-auto mt-6"></div>
    </div>

    {gigs.length > 0 ? (
      <ul class="list-none divide-y divide-n-stone">
        {gigs.map((gig) => {
          const d = formatDate(gig.date);
          return (
            <li class="group flex items-center gap-6 py-6">
              <!-- Date -->
              <div class="text-center min-w-[2.5rem]">
                <div class="font-serif text-n-ink text-2xl font-normal leading-none">{d.day}</div>
                <div class="text-n-fog text-[10px] tracking-widest uppercase font-light mt-1">{d.month}</div>
              </div>

              <div class="w-px h-8 bg-n-stone"></div>

              <!-- Info -->
              <div class="flex-1 min-w-0">
                <div class="font-serif text-n-ink text-lg">{gig.venue}</div>
                <div class="text-n-fog text-xs tracking-wide font-light mt-0.5">
                  {gig.city}{gig.country ? `, ${gig.country}` : ''} &mdash; {d.weekday}
                </div>
                {gig.description && (
                  <div class="text-n-fog text-xs mt-1 font-light italic">{gig.description}</div>
                )}
              </div>

              {gig.ticketUrl && (
                <a
                  href={gig.ticketUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[10px] tracking-widest uppercase text-n-ink border border-n-ink px-4 py-2 hover:bg-n-ink hover:text-n-white transition-all duration-200 font-light shrink-0"
                >
                  Tickets
                </a>
              )}
            </li>
          );
        })}
      </ul>
    ) : (
      <div class="text-center py-16 border border-n-stone">
        <p class="text-n-fog font-serif italic text-lg">No upcoming dates.</p>
        <p class="text-n-fog text-xs tracking-widest uppercase font-light mt-2">Check back soon</p>
      </div>
    )}

  </div>
</section>
