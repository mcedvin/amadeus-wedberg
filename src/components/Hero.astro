---
---

<section class="pt-[57px]">
  <!-- Photo with overlaid name -->
  <div class="relative overflow-hidden" style="height: 88vh;">
    <img
      src="/amadeus-hero.jpg"
      alt="Amadeus Wedberg playing drums"
      class="w-full h-full object-cover object-center grayscale"
    />
    <!-- Subtle gradient at bottom for text legibility -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>

    <!-- Large name overlaid at bottom -->
    <div class="absolute bottom-0 left-0 right-0 px-4 md:px-8 pb-4 md:pb-6">
      <h1
        class="font-serif text-white uppercase leading-[0.85] tracking-tight select-none"
        style="font-size: clamp(3.5rem, 12.5vw, 14rem);"
      >
        Amadeus
      </h1>
      <h1
        class="font-serif text-white/80 uppercase leading-[0.85] tracking-tight italic select-none"
        style="font-size: clamp(3rem, 10.5vw, 12rem);"
      >
        Wedberg
      </h1>
    </div>
  </div>

  <!-- Tagline below photo -->
  <div class="border-b border-n-stone">
    <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
      <p class="text-n-clay text-xs tracking-[0.35em] uppercase font-light">Jazz Drummer</p>
      <p class="text-n-clay text-xs tracking-[0.35em] uppercase font-light">Stockholm, Sweden</p>
    </div>
  </div>
</section>
