---
import { client } from '../lib/sanity';
import type { Settings } from '../lib/types';

const settings: Settings | null = await client.fetch(`*[_type == "settings"][0]`).catch(() => null);
const email = settings?.email ?? 'amadeus@example.com';
const soundcloud = settings?.soundcloudUrl ?? 'https://soundcloud.com/amadeus-wedberg';
const instagram = settings?.instagramUrl;
---

<footer id="contact" class="bg-n-white border-t border-n-stone py-24">
  <div class="max-w-4xl mx-auto px-6 text-center">

    <h2 class="font-serif text-n-ink text-4xl md:text-6xl font-normal italic mb-12">
      Contact
    </h2>

    <!-- Icon row -->
    <div class="flex justify-center gap-12">

      <!-- Email -->
      <a href={`mailto:${email}`} class="group flex flex-col items-center gap-3">
        <div class="w-12 h-12 border border-n-stone group-hover:border-n-clay group-hover:text-n-clay text-n-fog flex items-center justify-center transition-colors duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <span class="text-[10px] tracking-widest uppercase text-n-fog group-hover:text-n-clay transition-colors font-light">Mail</span>
      </a>

      <!-- SoundCloud -->
      <a href={soundcloud} target="_blank" rel="noopener noreferrer" class="group flex flex-col items-center gap-3">
        <div class="w-12 h-12 border border-n-stone group-hover:border-n-clay group-hover:text-n-clay text-n-fog flex items-center justify-center transition-colors duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M1.175 12.225c-.015-.067-.025-.135-.025-.2 0-.65.525-1.175 1.175-1.175.425 0 .8.225 1.012.563.238-.113.5-.175.775-.175.938 0 1.7.762 1.7 1.7 0 .025 0 .05-.002.075h.027a.9.9 0 010 1.8H2.362a1.188 1.188 0 01-.025-2.363l-.013-.025-.087-.2zm3.313-.638a2.738 2.738 0 00-.288-.475c.113-.025.225-.038.35-.038.863 0 1.563.7 1.563 1.563 0 .025-.003.05-.003.075h.475a.638.638 0 010 1.275H4.1a1.188 1.188 0 01.388-2.4zm3.9-2.05c-.3 0-.575.075-.825.2a3.025 3.025 0 00-2.875-2.063 3.05 3.05 0 00-1.1.2A3.763 3.763 0 000 11.45c0 2.075 1.688 3.75 3.763 3.75h5.075A2.538 2.538 0 0011.375 12.7a2.55 2.55 0 00-2.988-2.463v.3zm5.313-2.3a4.375 4.375 0 00-3.513 1.775A3.788 3.788 0 0112.4 11.45c0 .188-.013.375-.038.55h.188a2.95 2.95 0 002.95-2.95 2.938 2.938 0 00-1.8-2.713zm2.3.625c-.075 0-.15.012-.225.025a4.663 4.663 0 01.512 2.088c0 .688-.15 1.338-.413 1.925h.725a2.538 2.538 0 000-5.075c-.2 0-.4.025-.6.037zm2.575.9a5.2 5.2 0 01.262 1.625c0 .813-.188 1.588-.525 2.275H20a2 2 0 000-4c-.175 0-.35.025-.525.063l.1.037z"/>
          </svg>
        </div>
        <span class="text-[10px] tracking-widest uppercase text-n-fog group-hover:text-n-clay transition-colors font-light">SoundCloud</span>
      </a>

      <!-- Instagram (only if set) -->
      {instagram && (
        <a href={instagram} target="_blank" rel="noopener noreferrer" class="group flex flex-col items-center gap-3">
          <div class="w-12 h-12 border border-n-stone group-hover:border-n-clay group-hover:text-n-clay text-n-fog flex items-center justify-center transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </div>
          <span class="text-[10px] tracking-widest uppercase text-n-fog group-hover:text-n-clay transition-colors font-light">Instagram</span>
        </a>
      )}
    </div>

    <div class="w-8 h-px bg-n-stone mx-auto mt-16 mb-8"></div>
    <p class="text-n-fog text-[10px] tracking-widest uppercase font-light">
      &copy; {new Date().getFullYear()} Amadeus Wedberg
    </p>
  </div>
</footer>
