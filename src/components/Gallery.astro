---
import { client, urlFor } from '../lib/sanity';
import type { GalleryPhoto } from '../lib/types';

const photos: GalleryPhoto[] = await client
  .fetch(`*[_type == "galleryPhoto"] | order(date desc)`)
  .catch(() => []);
---

<section id="gallery" class="py-24 md:py-36 bg-n-sand">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-16">
      <p class="text-n-clay text-xs tracking-[0.4em] uppercase font-light mb-4">Photos</p>
      <h2 class="font-serif text-n-ink text-3xl md:text-4xl font-normal italic">Gallery</h2>
      <div class="w-8 h-px bg-n-stone mx-auto mt-6"></div>
    </div>

    {photos.length > 0 ? (
      <div class="columns-2 md:columns-3 gap-3 space-y-3">
        {photos.map((photo) => (
          <div class="break-inside-avoid group relative overflow-hidden">
            <img
              src={urlFor(photo.image).width(800).quality(85).url()}
              alt={photo.caption ?? 'Amadeus Wedberg'}
              loading="lazy"
              class="w-full object-cover transition-all duration-500 group-hover:scale-[1.03]"
            />
            {photo.caption && (
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <p class="text-white text-xs font-light">{photo.caption}</p>
              </div>
            )}
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-16 border border-n-stone">
        <p class="text-n-fog font-serif italic text-lg">Photos coming soon.</p>
      </div>
    )}

  </div>
</section>
