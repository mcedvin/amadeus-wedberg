---
const left = [
  { label: 'About', href: '#about' },
  { label: 'Listen', href: '#listen' },
  { label: 'Live', href: '#live' },
];
const right = [
  { label: 'Gallery', href: '#gallery' },
  { label: 'Contact', href: '#contact' },
];
---

<nav id="nav" class="fixed top-0 left-0 right-0 z-50 bg-n-white/90 backdrop-blur-sm border-b border-n-stone transition-all duration-300">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- Left links (desktop) -->
    <ul class="hidden md:flex gap-8 list-none flex-1">
      {left.map(link => (
        <li>
          <a href={link.href} class="text-n-fog hover:text-n-ink text-xs tracking-widest uppercase transition-colors duration-200 font-light">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Centered name -->
    <a href="#" class="font-serif text-n-ink text-base md:text-lg tracking-[0.2em] uppercase absolute left-1/2 -translate-x-1/2">
      Amadeus Wedberg
    </a>

    <!-- Right links (desktop) -->
    <ul class="hidden md:flex gap-8 list-none flex-1 justify-end">
      {right.map(link => (
        <li>
          <a href={link.href} class="text-n-fog hover:text-n-ink text-xs tracking-widest uppercase transition-colors duration-200 font-light">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2 ml-auto" aria-label="Toggle menu">
      <span class="block w-6 h-px bg-n-ink transition-all duration-300"></span>
      <span class="block w-6 h-px bg-n-ink transition-all duration-300"></span>
      <span class="block w-4 h-px bg-n-ink transition-all duration-300" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-n-white border-t border-n-stone">
    <ul class="flex flex-col list-none px-6 py-4 gap-4">
      {[...left, ...right].map(link => (
        <li>
          <a href={link.href} class="mobile-link text-n-fog hover:text-n-ink text-xs tracking-widest uppercase transition-colors font-light block py-1">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const bar3 = document.getElementById('bar3')!;

  toggle.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden', isOpen);
    bar3.style.width = isOpen ? '1rem' : '1.5rem';
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      bar3.style.width = '1rem';
    });
  });
</script>
